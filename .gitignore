# Editors
.vscode/
.idea/
*.swp
*~

# Lychgate runtime artifacts (downloaded lists, compiled blocklist, logs)
# These should never be committed — they're generated/downloaded at runtime
data/
*.log
*.tmp
*.bak

# User-local config (after `install.sh` these live in ~/.config/lychgate, not here)
src/lists-enabled.conf
src/allowlist-critical.txt
!src/lists-enabled.conf.example
!src/allowlist-critical.txt.example

# Build artifacts (future Swift app)
build/
DerivedData/
*.xcuserstate
